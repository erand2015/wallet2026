<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Warthog Flutter Wallet</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>warthog_flutter_wallet</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- ========== BACKUP & FILE PERMISSIONS ========== -->
	<!-- Enable file sharing for backup files -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	
	<!-- Document browser support -->
	<key>UISupportsDocumentBrowser</key>
	<true/>
	
	<!-- Photo library access for backup files -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Warthog Wallet needs access to save encrypted backup files</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Warthog Wallet needs access to read encrypted backup files</string>
	
	<!-- ========== BIOMETRIC AUTHENTICATION ========== -->
	<!-- Face ID / Touch ID permission -->
	<key>NSFaceIDUsageDescription</key>
	<string>Warthog Wallet uses Face ID to securely unlock your wallet</string>
	
	<!-- ========== NOTIFICATIONS ========== -->
	<!-- Push notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	
	<!-- ========== CAMERA FOR QR CODE ========== -->
	<!-- Camera permission for QR code scanning -->
	<key>NSCameraUsageDescription</key>
	<string>Warthog Wallet needs camera access to scan QR codes for sending and receiving WART</string>
	
	<!-- ========== NETWORK ========== -->
	<!-- Allow HTTP connections (for development node) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	
	<!-- ========== FILE TYPE DECLARATIONS FOR .wbe ========== -->
	<!-- Register .wbe file type for backup files -->
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.warthog.wallet.backup</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>wbe</string>
				</array>
			</dict>
			<key>UTTypeDescription</key>
			<string>Warthog Wallet Encrypted Backup</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
		</dict>
	</array>
	
	<!-- Document types for opening .wbe files -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Warthog Backup File</string>
			<key>LSHandlerRank</key>
			<string>Default</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.warthog.wallet.backup</string>
			</array>
		</dict>
	</array>
	
</dict>
</plist>